# Backend environment variables
# Copy this file to backend/.env and fill in real values — never commit backend/.env

PORT=3001
NODE_ENV=development
JWT_SECRET=<generate-a-64-char-random-string>
JWT_EXPIRES_IN=24h
DB_PATH=./data/centralmonitor.db
LOG_LEVEL=info

# Azure Blob Storage — store ONLY in .env or Azure App Service Application Settings
AZURE_STORAGE_CONNECTION_STRING=<your-connection-string-here>
AZURE_STORAGE_CONTAINER=allvenuesource

# SMTP (optional — leave blank to disable email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@centralmonitor.local

# Frontend app URL (used in user invite emails)
APP_URL=http://localhost:5173
